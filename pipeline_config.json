{
  "gate_commands": [
    {"name": "pytest", "command": "uv run pytest -x -q"},
    {"name": "lint", "command": "uv run ruff check . --ignore E501"}
  ],
  "app_start_command": "uv run uvicorn app.main:app --port 8734",
  "app_port": 8734,
  "health_url": "http://127.0.0.1:8734/health",
  "health_timeout": 30
}
